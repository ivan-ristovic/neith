#!/bin/bash

neith_dir="$( cd "$( dirname "${BASH_SOURCE[0]}" )" && pwd )"
source ${SHLIB_ROOT:-"$neith_dir/shlib/lib"}/lib.sh

function usage ()
{
    echo -e "usage: $0 [opts] [query...]"
    echo -e "opts:"
    echo -e "  [--add     | -a] <category> [query...]"
    echo -e "  [--push    | -p]"
    echo -e "  [--help    | -h]"
    echo -e "  [--verbose | -v]"
    echo
    echo "Environment:"
    echo -e "  NEITH_LIBS=$NEITH_LIBS"
    exit 2
}

SHORT_OPTS=h,v,p,a:
LONG_OPTS=help,verbose,push,add:
OPTS=$(getopt --alternative --name 'argument error' --options $SHORT_OPTS --longoptions $LONG_OPTS -- "$@") 
if [ $? -ne 0 ]; then
    std_fat "failed to parse provided arguments"
fi
eval set -- $OPTS

NEITH_CMD_ADD=""
NEITH_CMD_SEARCH=true
NEITH_PUSH_LIB_UPDATE=false

while :
do
    case "$1" in
        -a | --add)
            shift
            NEITH_CMD_ADD="$1"
            NEITH_CMD_SEARCH=false
            ;;
        -p | --push)
            NEITH_PUSH_LIB_UPDATE=true
            ;;
        -v | --verbose)
            export SHLIB_LOG_DEBUG=true
            ;;
        -h | --help)
            usage
            ;;
        --)
            shift;
            break
            ;;
        *)
            log_err "unknown option: $1"
            usage
            ;;
    esac
    shift;
done

rc_locations=(
    $(pwd)/neithrc
    $HOME/.config/neith/neithrc
    $HOME/.neithrc
)
for f in "${rc_locations[@]}"; do
    if io_is_file "$f"; then 
        log_dbg "loading rc config: $f"
        source "$f"
    fi
done

NEITH_FD_PATH=${NEITH_FD_PATH:-"fd"}
NEITH_FZF_PATH=${NEITH_FZF_PATH:-"fzf"}
NEITH_RG_PATH=${NEITH_RG_PATH:-"rg"}
NEITH_BAT_PATH=${NEITH_BAT_PATH:-"bat"}
NEITH_NOTE_TEMPLATE=${NEITH_NOTE_TEMPLATE:-"$neith_dir/.neith-note-template.md"}
NEITH_CACHE_DIR_NAME=${NEITH_CACHE_DIR_NAME:-".neith-cache"}
NEITH_CACHE_REFRESH_SECONDS=${NEITH_CACHE_REFRESH_SECONDS:-"60"}
assert_installed "$NEITH_FD_PATH"
assert_installed "$NEITH_FZF_PATH"
assert_installed "$NEITH_RG_PATH"
assert_installed "$NEITH_BAT_PATH"
assert_installed "man"
assert_installed "col"

log_dbg "NEITH_LIBS=$NEITH_LIBS"

# Parse lib folders
if ! test_var_set NEITH_LIBS ; then
    log_dbg "NEITH_LIBS not set, adding '$neith_dir' to libs"
    NEITH_LIBS="$neith_dir"
fi
libs=$(str_split ":" "$NEITH_LIBS")
libs=$(arr_uniq $libs)
readarray -t libs <<<"$libs"

function ensure_lib_cache ()
{
    local lib=$1
    local cache_dir gitignore pattern

    [ -d "$lib" ] || return 0

    cache_dir="$lib/$NEITH_CACHE_DIR_NAME"
    gitignore="$lib/.gitignore"
    pattern="/$NEITH_CACHE_DIR_NAME/"

    mkdir -p "$cache_dir" 2>/dev/null || return 1
    touch "$gitignore" 2>/dev/null || return 1
    if ! grep -qxF "$pattern" "$gitignore"; then
        { printf '%s\n' "$pattern" >> "$gitignore"; } 2>/dev/null || return 1
    fi
}

function choose_lib ()
{
    local lib_count
    lib_count=$(arr_size libs)
    if [ "$lib_count" -gt 1 ]; then
        for i in "${!libs[@]}"; do 
            printf "%s: %s\n" "$i" "${libs[$i]}"
        done
        read -p "Please select index of the lib to use (default: 0): " index
    fi
    lib=${libs[${index:-0}]}
    echo "$lib"
}

function str_trim ()
{
    local value=$1

    value="${value#"${value%%[![:space:]]*}"}"
    value="${value%"${value##*[![:space:]]}"}"
    printf '%s' "$value"
}

function title_from_query ()
{
    local query

    query=$(str_trim "$1")
    printf '%s' "$query" |
        tr '_-' '  ' |
        awk '{ for (i = 1; i <= NF; i++) $i = toupper(substr($i, 1, 1)) substr($i, 2); print }'
}

function slug_from_query ()
{
    local query slug

    query=$(str_trim "$1")
    slug=$(printf '%s' "$query" |
        tr '[:upper:]' '[:lower:]' |
        sed -E 's/[^a-z0-9]+/-/g; s/^-+//; s/-+$//')

    printf '%s' "${slug:-note}"
}

function render_note_template ()
{
    local title=$1
    local target=$2
    local line

    if [ -f "$NEITH_NOTE_TEMPLATE" ]; then
        while IFS= read -r line || [ -n "$line" ]; do
            printf '%s\n' "${line//\{\{TITLE\}\}/$title}"
        done < "$NEITH_NOTE_TEMPLATE" > "$target"
    else
        {
            printf '# %s\n\n' "$title"
            printf '> Manually created note. Verify commands and references before using them on important systems.\n\n'
            printf 'Write the task-focused note here.\n\n'
            printf '```bash\n# command or snippet\n```\n\n'
            printf '## References\n\n'
            printf -- '- TODO: add reference\n'
        } > "$target"
    fi
}

function note_body_line ()
{
    local path=$1
    local line

    line=$(grep -n -m 1 '^Write the task-focused note here\.$' "$path" | cut -d: -f1)
    printf '%s' "${line:-1}"
}

function note_path_for ()
{
    local dir=$1
    local query=$2
    local slug

    slug=$(slug_from_query "$query")
    printf '%s/%s.md' "$dir" "$slug"
}

function create_note ()
{
    local dir=$1
    local query=$2
    local title path tmp

    query=$(str_trim "$query")
    [ -n "$query" ] || std_fat "note title/query must not be empty"

    mkdir -p "$dir" || std_fat "failed to create directory: $dir"
    path=$(note_path_for "$dir" "$query")

    if [ ! -e "$path" ]; then
        title=$(title_from_query "$query")
        tmp="${path}.tmp.$$"
        render_note_template "$title" "$tmp"
        mv "$tmp" "$path" || std_fat "failed to create note: $path"
    fi

    printf '%s' "$path"
}

# Add
if [ -n "$NEITH_CMD_ADD" ]; then
    lib=$(choose_lib)
    log_dbg "Selected lib: ${lib}"
    path=$(os_path "$lib/$NEITH_CMD_ADD")
    if [ -n "${*:-}" ]; then
        path=$(create_note "$path" "${*:-}")
        line=$(note_body_line "$path")
        log_exec "$EDITOR" "$path" "+$line"
    else
        log_exec "$EDITOR" "$path"
    fi
fi

# Push
if "$NEITH_PUSH_LIB_UPDATE"; then
    lib=$(choose_lib)
    log_dbg "Selected lib: ${lib}"
    pushd "$lib" || std_fat "failed to enter dir: $lib"
    set -e
    git pull
    git add --all
    git commit -m "neith: update lib"
    git push
    popd
    exit 0
fi

# Search
if [ "$NEITH_CMD_SEARCH" == "true" ]; then
    INITIAL_QUERY="${*:-}"

    tmp_dir=$(mktemp -d "${TMPDIR:-/tmp}/neith-fzf.XXXXXX")
    helper="$tmp_dir/helper"
    libs_file="$tmp_dir/libs"
    printf '%s\n' "${libs[@]}" > "$libs_file"
    printf 'file' > "$tmp_dir/mode"
    printf 'file' > "$tmp_dir/file_mode"
    printf 'fuzzy' > "$tmp_dir/content_mode"
    printf '' > "$tmp_dir/live_query"
    printf '' > "$tmp_dir/pre_filter_mode"
    printf '' > "$tmp_dir/frozen"
    printf '' > "$tmp_dir/add_prev_mode"
    printf '' > "$tmp_dir/add_prev_query"
    printf '' > "$tmp_dir/add_query"
    printf '' > "$tmp_dir/add_seed"
    printf '' > "$tmp_dir/add_root"
    printf '' > "$tmp_dir/file_source_key"
    printf '' > "$tmp_dir/content_fuzzy_source_key"

    for lib in "${libs[@]}"; do
        ensure_lib_cache "$lib" || log_dbg "failed to prepare cache directory for lib: $lib"
    done

    function cleanup_search ()
    {
        rm -rf "$tmp_dir"
    }
    trap cleanup_search EXIT

    cat > "$helper" <<'NEITH_FZF_HELPER'
#!/usr/bin/env bash
set -u

tmp_dir=${NEITH_FZF_TMP:?}
libs_file=${NEITH_FZF_LIBS_FILE:?}
fd_path=${NEITH_FD_PATH:-fd}
fzf_path=${NEITH_FZF_PATH:-fzf}
rg_path=${NEITH_RG_PATH:-rg}
bat_path=${NEITH_BAT_PATH:-bat}
note_template=${NEITH_NOTE_TEMPLATE:-}
cache_dir_name=${NEITH_CACHE_DIR_NAME:-.neith-cache}
cache_version="v1"
cache_refresh_seconds=${NEITH_CACHE_REFRESH_SECONDS:-60}
if [[ ! "$cache_refresh_seconds" =~ ^[0-9]+$ ]]; then
    cache_refresh_seconds=60
fi
editor=${EDITOR:-vi}
tab=$'\t'
man_query_sep=$'\037'

mapfile -t libs < "$libs_file"

mode_file="$tmp_dir/mode"
file_mode_file="$tmp_dir/file_mode"
content_mode_file="$tmp_dir/content_mode"
pre_filter_mode_file="$tmp_dir/pre_filter_mode"
live_query_file="$tmp_dir/live_query"
frozen_file="$tmp_dir/frozen"
add_prev_mode_file="$tmp_dir/add_prev_mode"
add_prev_query_file="$tmp_dir/add_prev_query"
add_query_file="$tmp_dir/add_query"
add_seed_file="$tmp_dir/add_seed"
add_root_file="$tmp_dir/add_root"
file_source_key_file="$tmp_dir/file_source_key"
content_fuzzy_source_key_file="$tmp_dir/content_fuzzy_source_key"
man_dir="$tmp_dir/man"
mkdir -p "$man_dir"

function read_state ()
{
    local file=$1
    local default=$2

    if [[ -s "$file" ]]; then
        cat "$file"
    else
        printf '%s' "$default"
    fi
}

function write_state ()
{
    local file=$1
    local value=$2

    printf '%s' "$value" > "$file"
}

function cache_path_for ()
{
    local prefix=$1
    local key=$2
    local checksum

    checksum=$(printf '%s' "$key" | cksum | awk '{ print $1 }')
    printf '%s/%s.%s' "$tmp_dir" "$prefix" "$checksum"
}

function cache_once ()
{
    local cache=$1
    local tmp

    shift
    if [[ ! -e "$cache" ]]; then
        tmp="${cache}.tmp.$$"
        if "$@" > "$tmp"; then
            mv "$tmp" "$cache"
        else
            rm -f "$tmp"
            return 1
        fi
    fi

    cat "$cache"
}

function prepare_lib_cache ()
{
    local lib=$1
    local cache_dir gitignore pattern

    [[ -d "$lib" ]] || return 0

    cache_dir="$lib/$cache_dir_name"
    gitignore="$lib/.gitignore"
    pattern="/$cache_dir_name/"

    mkdir -p "$cache_dir" 2>/dev/null || return 1
    touch "$gitignore" 2>/dev/null || return 1
    if ! grep -qxF "$pattern" "$gitignore"; then
        { printf '%s\n' "$pattern" >> "$gitignore"; } 2>/dev/null || return 1
    fi
}

function lib_cache_path ()
{
    local lib=$1
    local name=$2

    printf '%s/%s/%s.%s' "$lib" "$cache_dir_name" "$cache_version" "$name"
}

function cache_age_seconds ()
{
    local cache=$1
    local now mtime

    [[ -e "$cache" ]] || return 1
    now=$(date +%s)
    mtime=$(stat -c %Y "$cache" 2>/dev/null) || return 1
    printf '%s' "$((now - mtime))"
}

function build_lib_cache ()
{
    local lib=$1
    local name=$2
    local builder=$3
    local cache tmp

    shift 3
    if ! prepare_lib_cache "$lib"; then
        "$builder" "$lib" "$@"
        return
    fi

    cache=$(lib_cache_path "$lib" "$name")
    tmp="${cache}.tmp.$$"
    if "$builder" "$lib" "$@" > "$tmp"; then
        mv "$tmp" "$cache"
        cat "$cache"
    else
        rm -f "$tmp"
        "$builder" "$lib" "$@"
    fi
}

function lib_cache_once ()
{
    local lib=$1
    local name=$2
    local builder=$3
    local cache

    shift 3
    if ! prepare_lib_cache "$lib"; then
        "$builder" "$lib" "$@"
        return
    fi

    cache=$(lib_cache_path "$lib" "$name")
    if [[ ! -e "$cache" ]]; then
        build_lib_cache "$lib" "$name" "$builder" "$@"
        return
    fi

    cat "$cache"
}

function refresh_lib_cache_if_stale ()
{
    local lib=$1
    local name=$2
    local builder=$3
    local cache age

    shift 3
    prepare_lib_cache "$lib" || return 0

    cache=$(lib_cache_path "$lib" "$name")
    age=$(cache_age_seconds "$cache" || printf '%s' "$((cache_refresh_seconds + 1))")
    if [[ "$age" -ge "$cache_refresh_seconds" ]]; then
        build_lib_cache "$lib" "$name" "$builder" "$@" >/dev/null
    fi
}

function refresh_lib_caches ()
{
    local lib=$1

    refresh_lib_cache_if_stale "$lib" "paths-f" build_lib_paths f file
    refresh_lib_cache_if_stale "$lib" "paths-d" build_lib_paths d dir
    refresh_lib_cache_if_stale "$lib" "add-dirs" build_lib_dirs_raw
    refresh_lib_cache_if_stale "$lib" "content-fuzzy" build_lib_content_fuzzy
}

function refresh_caches ()
{
    local lib

    for lib in "${libs[@]}"; do
        refresh_lib_caches "$lib"
    done
}

function rebuild_lib_caches ()
{
    local lib=$1

    build_lib_cache "$lib" "paths-f" build_lib_paths f file >/dev/null
    build_lib_cache "$lib" "paths-d" build_lib_paths d dir >/dev/null
    build_lib_cache "$lib" "add-dirs" build_lib_dirs_raw >/dev/null
    build_lib_cache "$lib" "content-fuzzy" build_lib_content_fuzzy >/dev/null
}

function rebuild_caches ()
{
    local lib

    for lib in "${libs[@]}"; do
        rebuild_lib_caches "$lib"
    done
}

function rebuild_caches_and_source ()
{
    rebuild_caches
    source_current
}

function current_mode ()
{
    read_state "$mode_file" "file"
}

function prompt_for ()
{
    case "$1" in
        file) printf 'F:file> ' ;;
        dir) printf 'F:dir> ' ;;
        content_fuzzy) printf 'C:fuzzy> ' ;;
        content_lit) printf 'C:lit> ' ;;
        filter_file|filter_dir) printf 'F:filter> ' ;;
        filter_content_fuzzy|filter_content_lit) printf 'C:filter> ' ;;
        add) printf 'A:dir> ' ;;
        *) printf 'F:file> ' ;;
    esac
}

function search_action_for ()
{
    case "$1" in
        content_lit) printf 'disable-search' ;;
        *) printf 'enable-search' ;;
    esac
}

function header_for ()
{
    case "$1" in
        add) printf 'Enter: select/create | Ctrl-A: cancel | Esc: quit' ;;
        *) printf 'Tab: mode | Ctrl-T: toggle | Ctrl-F: filter | Ctrl-R: refresh | Ctrl-A: add | Enter: open | Esc: quit' ;;
    esac
}

function actions_for_mode ()
{
    local mode=$1

    printf 'change-prompt(%s)+change-header(%s)+%s' \
        "$(prompt_for "$mode")" "$(header_for "$mode")" "$(search_action_for "$mode")"
}

function emit_candidate ()
{
    local kind=$1
    local path=$2
    local line=$3
    local title=$4
    local display=$5

    printf '%s\t%s\t%s\t%s\t%s\n' "$kind" "$path" "$line" "$title" "$display"
}

function emit_content_candidate ()
{
    local kind=$1
    local path=$2
    local line=$3
    local title=$4
    local text=$5
    local context=$6

    text=${text//$'\t'/    }
    printf '%s\t%s\t%s\t%s\t%s\t%s\n' "$kind" "$path" "$line" "$title" "$text" "$context"
}

function trim_string ()
{
    local value=$1

    value="${value#"${value%%[![:space:]]*}"}"
    value="${value%"${value##*[![:space:]]}"}"
    printf '%s' "$value"
}

function split_man_query ()
{
    local query=$1
    local trimmed first rest section title remainder

    trimmed=$(trim_string "$query")
    [[ -n "$trimmed" ]] || return 1

    if [[ "$trimmed" =~ ^([^[:space:]()]+)\(([^()[:space:]]+)\)([[:space:]]+(.*))?$ ]]; then
        title=${BASH_REMATCH[1]}
        section=${BASH_REMATCH[2]}
        remainder=${BASH_REMATCH[4]:-}
        printf '%s%s%s%s%s\n' "$section" "$man_query_sep" "$title" "$man_query_sep" "$remainder"
        return 0
    fi

    first="${trimmed%%[[:space:]]*}"
    rest="${trimmed#"$first"}"
    rest=$(trim_string "$rest")

    if [[ -n "$rest" && "$first" =~ ^([0-9][A-Za-z0-9]*|n|l)$ ]]; then
        section=$first
        title="${rest%%[[:space:]]*}"
        remainder="${rest#"$title"}"
        remainder=$(trim_string "$remainder")
        [[ -n "$title" ]] || return 1
        printf '%s%s%s%s%s\n' "$section" "$man_query_sep" "$title" "$man_query_sep" "$remainder"
        return 0
    fi

    title=$first
    remainder=$rest
    printf '%s%s%s%s%s\n' "" "$man_query_sep" "$title" "$man_query_sep" "$remainder"
}

function title_from_query ()
{
    local query

    query=$(trim_string "$1")
    printf '%s' "$query" |
        tr '_-' '  ' |
        awk '{ for (i = 1; i <= NF; i++) $i = toupper(substr($i, 1, 1)) substr($i, 2); print }'
}

function slug_from_query ()
{
    local query slug

    query=$(trim_string "$1")
    slug=$(printf '%s' "$query" |
        tr '[:upper:]' '[:lower:]' |
        sed -E 's/[^a-z0-9]+/-/g; s/^-+//; s/-+$//')

    printf '%s' "${slug:-note}"
}

function slug_path_component ()
{
    slug_from_query "$1"
}

function note_body_line ()
{
    local path=$1
    local line

    line=$(grep -n -m 1 '^Write the task-focused note here\.$' "$path" | cut -d: -f1)
    printf '%s' "${line:-1}"
}

function render_note_template ()
{
    local title=$1
    local target=$2
    local line

    if [[ -n "$note_template" && -f "$note_template" ]]; then
        while IFS= read -r line || [[ -n "$line" ]]; do
            printf '%s\n' "${line//\{\{TITLE\}\}/$title}"
        done < "$note_template" > "$target"
    else
        {
            printf '# %s\n\n' "$title"
            printf '> Manually created note. Verify commands and references before using them on important systems.\n\n'
            printf 'Write the task-focused note here.\n\n'
            printf '```bash\n# command or snippet\n```\n\n'
            printf '## References\n\n'
            printf -- '- TODO: add reference\n'
        } > "$target"
    fi
}

function create_note ()
{
    local dir=$1
    local query=$2
    local title slug path tmp

    query=$(trim_string "$query")
    [[ -n "$query" ]] || return 1

    mkdir -p "$dir" || return 1
    slug=$(slug_from_query "$query")
    path="$dir/$slug.md"

    if [[ ! -e "$path" ]]; then
        title=$(title_from_query "$query")
        tmp="${path}.tmp.$$"
        render_note_template "$title" "$tmp" || return 1
        mv "$tmp" "$path" || return 1
    fi

    printf '%s' "$path"
}

function lib_for_path ()
{
    local path=$1
    local lib

    for lib in "${libs[@]}"; do
        if [[ "$path" == "$lib" || "$path" == "$lib"/* ]]; then
            printf '%s' "$lib"
            return 0
        fi
    done

    return 1
}

function relative_to_lib ()
{
    local path=$1
    local lib=$2

    if [[ "$path" == "$lib" ]]; then
        printf '.'
    else
        printf '%s' "${path#"$lib"/}"
    fi
}

function selected_item_path ()
{
    local item=$1
    local kind path line title display

    IFS=$'\t' read -r kind path line title display <<< "$item"
    printf '%s' "${path:-}"
}

function selected_item_title ()
{
    local item=$1
    local kind path line title display base

    IFS=$'\t' read -r kind path line title display <<< "$item"
    if [[ -n "${title:-}" ]]; then
        printf '%s' "$title"
        return
    fi

    [[ -n "${path:-}" ]] || return 0
    base=$(basename "$path")
    base="${base%.md}"
    base="${base%.txt}"
    title_from_query "$base"
}

function selected_item_parent_seed ()
{
    local item=$1
    local kind path line title display parent lib rel

    IFS=$'\t' read -r kind path line title display <<< "$item"
    [[ -n "${path:-}" ]] || return 1

    case "$kind" in
        dir|add_dir) parent="$path" ;;
        file|content) parent=$(dirname "$path") ;;
        *) return 1 ;;
    esac

    lib=$(lib_for_path "$parent") || return 1
    rel=$(relative_to_lib "$parent" "$lib")
    [[ "$rel" != "." ]] || return 1
    printf '%s' "$rel"
}

function first_query_word ()
{
    local query=$1

    query=$(trim_string "$query")
    [[ -n "$query" ]] || return 1
    printf '%s' "${query%%[[:space:]]*}"
}

function safe_relative_dir ()
{
    local value=$1
    local part out slug

    value=$(trim_string "$value")
    value="${value#./}"
    value="${value#/}"
    [[ -n "$value" ]] || return 1

    IFS='/' read -ra parts <<< "$value"
    out=""
    for part in "${parts[@]}"; do
        part=$(trim_string "$part")
        [[ "$part" != "." && "$part" != ".." ]] || return 1
        slug=$(slug_path_component "$part")
        [[ -n "$slug" && "$slug" != "note" ]] || continue
        if [[ -n "$out" ]]; then
            out+="/$slug"
        else
            out="$slug"
        fi
    done

    [[ -n "$out" ]] || return 1
    printf '%s' "$out"
}

function choose_new_dir_root ()
{
    local root index

    root=$(read_state "$add_root_file" "")
    if [[ -n "$root" ]]; then
        printf '%s' "$root"
        return 0
    fi

    if [[ "${#libs[@]}" -eq 1 ]]; then
        printf '%s' "${libs[0]}"
        return 0
    fi

    printf 'Select library root for the new directory:\n' > /dev/tty
    for index in "${!libs[@]}"; do
        printf '%s: %s\n' "$index" "${libs[$index]}" > /dev/tty
    done
    printf 'Index: ' > /dev/tty
    read -r index < /dev/tty
    [[ "$index" =~ ^[0-9]+$ && -n "${libs[$index]:-}" ]] || return 1
    printf '%s' "${libs[$index]}"
}

function man_section_from_path ()
{
    local path=$1
    local base

    base=$(basename "$path")
    while [[ "$base" =~ \.(gz|bz2|xz|lzma|zst|br|lz)$ ]]; do
        base="${base%.*}"
    done

    if [[ "$base" == *.* ]]; then
        printf '%s' "${base##*.}"
    fi
}

function man_page_label ()
{
    local title=$1
    local section=$2

    if [[ -n "$section" ]]; then
        printf '%s(%s)' "$title" "$section"
    else
        printf '%s' "$title"
    fi
}

function safe_man_component ()
{
    local value=$1

    value="${value//[^A-Za-z0-9_.+-]/_}"
    printf '%s' "${value:-man}"
}

function resolve_man_pages ()
{
    local title=$1
    local section=${2:-}

    [[ -n "$title" ]] || return 1

    if [[ -n "$section" ]]; then
        man -wa -- "$section" "$title" 2>/dev/null || true
    else
        man -wa -- "$title" 2>/dev/null || true
    fi
}

function render_man_path ()
{
    local title=$1
    local section=$2
    local source_path=$3
    local safe_title safe_section key file tmp

    safe_title=$(safe_man_component "$title")
    safe_section=$(safe_man_component "${section:-unknown}")
    key=$(printf '%s' "$source_path" | cksum | awk '{ print $1 }')
    file="$man_dir/${safe_title}.${safe_section}.${key}.txt"
    tmp="$file.tmp.$$"

    if [[ ! -s "$file" ]]; then
        if man -l -- "$source_path" 2>/dev/null | col -b > "$tmp" && [[ -s "$tmp" ]]; then
            mv "$tmp" "$file"
        else
            rm -f "$tmp"
            return 1
        fi
    fi

    printf '%s\n' "$file"
}

function build_lib_paths ()
{
    local lib=$1
    local fd_type=$2
    local kind=$3
    local path

    "$fd_path" -a -t "$fd_type" --exclude "$cache_dir_name" . "$lib" 2>/dev/null |
        while IFS= read -r path; do
            emit_candidate "$kind" "$path" 0 "" "$path"
        done
}

function source_paths ()
{
    local fd_type=$1
    local kind=$2
    local lib

    for lib in "${libs[@]}"; do
        lib_cache_once "$lib" "paths-${fd_type}" build_lib_paths "$fd_type" "$kind"
    done
}

function build_lib_dirs_raw ()
{
    local lib=$1
    local path

    emit_candidate "add_dir" "$lib" 0 "$lib" "."
    "$fd_path" -a -t d --exclude "$cache_dir_name" . "$lib" 2>/dev/null |
        while IFS= read -r path; do
            emit_candidate "add_dir" "$path" 0 "$lib" "$(relative_to_lib "$path" "$lib")"
        done
}

function source_lib_add_dirs ()
{
    local lib=$1
    local label kind path line title display rel
    local multi=false

    if [[ "${#libs[@]}" -gt 1 ]]; then
        multi=true
    fi

    label=$(basename "$lib")
    lib_cache_once "$lib" "add-dirs" build_lib_dirs_raw |
        while IFS=$'\t' read -r kind path line title display; do
            [[ -n "${path:-}" ]] || continue
            rel=${display:-.}
            if "$multi"; then
                display="${rel}  [$label]"
            else
                display="$rel"
            fi
            emit_candidate "add_dir" "$path" 0 "$title" "$display"
        done
}

function source_add_dirs ()
{
    local lib

    for lib in "${libs[@]}"; do
        source_lib_add_dirs "$lib"
    done
}

function build_man_pages ()
{
    local title=$1
    local section=$2
    local source_path page_section file label

    while IFS= read -r source_path; do
        [[ -n "$source_path" ]] || continue

        page_section=$(man_section_from_path "$source_path")
        page_section=${page_section:-$section}
        file=$(render_man_path "$title" "$page_section" "$source_path") || continue
        label=$(man_page_label "$title" "$page_section")

        printf '%s\t%s\n' "$file" "$label"
    done < <(resolve_man_pages "$title" "$section")
}

function source_man_pages ()
{
    local title=$1
    local section=$2
    local cache

    cache=$(cache_path_for "man_pages" "$section:$title")
    cache_once "$cache" build_man_pages "$title" "$section"
}

function source_man_file ()
{
    local query=$1
    local section title remainder file label display

    IFS=$man_query_sep read -r section title remainder < <(split_man_query "$query") || return 0

    while IFS=$'\t' read -r file label; do
        [[ -n "$file" && -n "$label" ]] || continue

        display="man:${label}"
        if [[ -n "$remainder" ]]; then
            display+=" ${remainder}"
        fi
        display+=" -> ${file}"

        emit_candidate "man_file" "$file" 0 "$label" "$display"
    done < <(source_man_pages "$title" "$section")
}

function run_rg ()
{
    local mode=$1
    local pattern=$2
    shift 2

    [[ -n "$pattern" ]] || return 0

    if [[ "$mode" == "content_lit" ]]; then
        "$rg_path" --column --line-number --no-heading --color=never \
            --with-filename \
            --ignore-case --fixed-strings \
            --glob "!**/$cache_dir_name/**" \
            --field-match-separator "$tab" \
            --field-context-separator "$tab" \
            -- "$pattern" "$@" 2>/dev/null || true
    else
        "$rg_path" --column --line-number --no-heading --color=never \
            --with-filename \
            --ignore-case \
            --glob "!**/$cache_dir_name/**" \
            --field-match-separator "$tab" \
            --field-context-separator "$tab" \
            -- "$pattern" "$@" 2>/dev/null || true
    fi
}

function source_content ()
{
    local mode=$1
    local query=$2

    case "$mode" in
        content_fuzzy)
            source_content_fuzzy
            ;;
        content_lit)
            source_content_lit "$query"
            ;;
    esac
}

function build_lib_content_fuzzy ()
{
    local lib=$1
    local path line column text

    {
        "$rg_path" --column --line-number --no-heading --color=never \
            --with-filename \
            --glob "!**/$cache_dir_name/**" \
            --field-match-separator "$tab" \
            --field-context-separator "$tab" \
            -- "" "$lib" 2>/dev/null || true
    } |
    while IFS=$'\t' read -r path line column text; do
        [[ -n "${path:-}" && -n "${line:-}" ]] || continue
        emit_content_candidate "content" "$path" "$line" "" "$text" "${path}:${line}:${column}"
    done
}

function source_content_fuzzy ()
{
    local lib

    for lib in "${libs[@]}"; do
        lib_cache_once "$lib" "content-fuzzy" build_lib_content_fuzzy
    done
}

function source_content_lit ()
{
    local query=$1
    local path line column text

    run_rg "content_lit" "$query" "${libs[@]}" |
    while IFS=$'\t' read -r path line column text; do
        [[ -n "${path:-}" && -n "${line:-}" ]] || continue
        emit_content_candidate "content" "$path" "$line" "" "$text" "${path}:${line}:${column}"
    done
}

function man_pages_key_suffix ()
{
    local title=$1
    local section=$2
    local pages

    pages=$(source_man_pages "$title" "$section")
    [[ -n "$pages" ]] || return 0
    printf '%s%s%s' "$section" "$man_query_sep" "$title"
}

function file_source_key ()
{
    local query=$1
    local section title remainder key

    IFS=$man_query_sep read -r section title remainder < <(split_man_query "$query") || return 0
    key=$(man_pages_key_suffix "$title" "$section")
    [[ -n "$key" ]] || return 0
    printf '%s%s%s' "$key" "$man_query_sep" "$remainder"
}

function content_fuzzy_source_key ()
{
    local query=$1
    local section title remainder

    IFS=$man_query_sep read -r section title remainder < <(split_man_query "$query") || return 0
    man_pages_key_suffix "$title" "$section"
}

function source_man_content ()
{
    local mode=$1
    local query=$2
    local section title remainder pattern file label path line column text

    IFS=$man_query_sep read -r section title remainder < <(split_man_query "$query") || return 0
    pattern=${remainder:-$title}

    while IFS=$'\t' read -r file label; do
        [[ -n "$file" && -n "$label" ]] || continue

        case "$mode" in
            content_fuzzy)
                cache_once "$(cache_path_for "man_content_fuzzy" "$section:$title:$file")" \
                    source_man_content_fuzzy_uncached "$file" "$label"
                ;;
            content_lit)
                run_rg "$mode" "$pattern" "$file" |
                    while IFS=$'\t' read -r path line column text; do
                        [[ -n "${line:-}" ]] || continue
                        emit_content_candidate "man_content" "$file" "$line" "$label" "man:${label}: ${text}" "${line}:${column}"
                    done
                ;;
        esac
    done < <(source_man_pages "$title" "$section")
}

function source_man_content_fuzzy_uncached ()
{
    local file=$1
    local label=$2
    local path line column text

    {
        "$rg_path" --column --line-number --no-heading --color=never \
            --with-filename \
            --field-match-separator "$tab" \
            --field-context-separator "$tab" \
            -- "" "$file" 2>/dev/null || true
    } |
        while IFS=$'\t' read -r path line column text; do
            [[ -n "${line:-}" ]] || continue
            emit_content_candidate "man_content" "$file" "$line" "$label" "man:${label}: ${text}" "${line}:${column}"
        done
}

function source_for ()
{
    local mode=$1
    local query=$2

    case "$mode" in
        file)
            write_state "$file_source_key_file" "$(file_source_key "$query")"
            source_man_file "$query"
            source_paths f file
            ;;
        dir)
            source_paths d dir
            ;;
        content_fuzzy|content_lit)
            if [[ "$mode" == "content_fuzzy" ]]; then
                write_state "$content_fuzzy_source_key_file" "$(content_fuzzy_source_key "$query")"
            fi
            source_content "$mode" "$query"
            source_man_content "$mode" "$query"
            ;;
        filter)
            cat "$frozen_file" 2>/dev/null || true
            ;;
        add)
            source_add_dirs
            ;;
    esac
}

function source_current ()
{
    source_for "$(current_mode)" "${FZF_QUERY:-}"
}

function source_live ()
{
    source_for "$(current_mode)" "$(read_state "$live_query_file" "")"
}

function source_filter ()
{
    cat "$frozen_file" 2>/dev/null || true
}

function source_add ()
{
    source_add_dirs
}

function live_query ()
{
    read_state "$live_query_file" ""
}

function add_seed ()
{
    read_state "$add_seed_file" ""
}

function add_prev_query ()
{
    read_state "$add_prev_query_file" ""
}

function on_change ()
{
    local mode query key last_key

    mode=$(current_mode)
    case "$mode" in
        filter|add|dir)
            printf 'ignore\n'
            ;;
        file)
            query=${FZF_QUERY:-}
            key=$(file_source_key "$query")
            last_key=$(read_state "$file_source_key_file" "")
            if [[ "$key" == "$last_key" ]]; then
                printf 'ignore\n'
            else
                printf 'reload(%s source)\n' "$0"
            fi
            ;;
        content_fuzzy)
            query=${FZF_QUERY:-}
            key=$(content_fuzzy_source_key "$query")
            last_key=$(read_state "$content_fuzzy_source_key_file" "")
            if [[ "$key" == "$last_key" ]]; then
                printf 'ignore\n'
            else
                printf 'reload(%s source)\n' "$0"
            fi
            ;;
        *)
            printf 'reload(%s source)\n' "$0"
            ;;
    esac
}

function file_mode_name ()
{
    read_state "$file_mode_file" "file"
}

function content_mode_name ()
{
    local content_mode

    content_mode=$(read_state "$content_mode_file" "fuzzy")
    printf 'content_%s' "$content_mode"
}

function opposite_top_mode ()
{
    case "$1" in
        file|dir) content_mode_name ;;
        content_fuzzy|content_lit) file_mode_name ;;
        *) file_mode_name ;;
    esac
}

function switch_top ()
{
    local mode new_mode

    mode=$(current_mode)
    if [[ "$mode" == "add" ]]; then
        printf 'ignore\n'
        return
    fi

    if [[ "$mode" == "filter" ]]; then
        mode=$(read_state "$pre_filter_mode_file" "file")
        new_mode=$(opposite_top_mode "$mode")
        write_state "$mode_file" "$new_mode"
        printf '%s+transform-query(%s live-query)+reload-sync(%s source-live)\n' \
            "$(actions_for_mode "$new_mode")" "$0" "$0"
        return
    fi

    new_mode=$(opposite_top_mode "$mode")
    write_state "$mode_file" "$new_mode"
    printf '%s+reload(%s source)\n' "$(actions_for_mode "$new_mode")" "$0"
}

function toggle_submode ()
{
    local mode new_mode

    mode=$(current_mode)
    case "$mode" in
        file)
            new_mode=dir
            write_state "$file_mode_file" "$new_mode"
            ;;
        dir)
            new_mode=file
            write_state "$file_mode_file" "$new_mode"
            ;;
        content_fuzzy)
            new_mode=content_lit
            write_state "$content_mode_file" "lit"
            ;;
        content_lit)
            new_mode=content_fuzzy
            write_state "$content_mode_file" "fuzzy"
            ;;
        filter|add)
            printf 'ignore\n'
            return
            ;;
        *)
            new_mode=file
            write_state "$file_mode_file" "$new_mode"
            ;;
    esac

    write_state "$mode_file" "$new_mode"
    printf '%s+reload(%s source)\n' "$(actions_for_mode "$new_mode")" "$0"
}

function freeze_results ()
{
    local mode=$1
    local query=$2

    if [[ "$mode" == "file" || "$mode" == "dir" || "$mode" == "content_fuzzy" ]]; then
        source_for "$mode" "$query" |
            FZF_DEFAULT_COMMAND= FZF_DEFAULT_OPTS= "$fzf_path" \
                --filter "$query" \
                --delimiter "$tab" \
                --with-nth '5..' \
                --nth '1' \
                --ignore-case > "$frozen_file" || true
    else
        source_for "$mode" "$query" > "$frozen_file"
    fi
}

function toggle_filter ()
{
    local mode query filter_prompt

    mode=$(current_mode)
    if [[ "$mode" == "add" ]]; then
        printf 'ignore\n'
        return
    fi

    if [[ "$mode" == "filter" ]]; then
        mode=$(read_state "$pre_filter_mode_file" "file")
        write_state "$mode_file" "$mode"
        printf '%s+transform-query(%s live-query)+reload-sync(%s source-live)\n' \
            "$(actions_for_mode "$mode")" "$0" "$0"
        return
    fi

    query=${FZF_QUERY:-}
    write_state "$pre_filter_mode_file" "$mode"
    write_state "$live_query_file" "$query"
    freeze_results "$mode" "$query"
    write_state "$mode_file" "filter"

    case "$mode" in
        file|dir) filter_prompt=$(prompt_for filter_file) ;;
        *) filter_prompt=$(prompt_for filter_content_fuzzy) ;;
    esac

    printf 'reload-sync(%s source-filter)+change-prompt(%s)+enable-search+clear-query\n' \
        "$0" "$filter_prompt"
}

function cancel_add ()
{
    local mode query filter_prompt pre_filter

    mode=$(read_state "$add_prev_mode_file" "file")
    query=$(read_state "$add_prev_query_file" "")
    write_state "$mode_file" "$mode"

    if [[ "$mode" == "filter" ]]; then
        pre_filter=$(read_state "$pre_filter_mode_file" "file")
        case "$pre_filter" in
            file|dir) filter_prompt=$(prompt_for filter_file) ;;
            *) filter_prompt=$(prompt_for filter_content_fuzzy) ;;
        esac
        printf 'change-prompt(%s)+change-header(%s)+enable-search+transform-query(%s add-prev-query)+reload-sync(%s source-filter)\n' \
            "$filter_prompt" "$(header_for "$mode")" "$0" "$0"
        return
    fi

    printf '%s+transform-query(%s add-prev-query)+reload-sync(%s source)\n' \
        "$(actions_for_mode "$mode")" "$0" "$0"
}

function toggle_add ()
{
    local item=${1:-}
    local mode query seed path root

    mode=$(current_mode)
    if [[ "$mode" == "add" ]]; then
        cancel_add
        return
    fi

    if [[ "$mode" == "filter" ]]; then
        query=$(live_query)
    else
        query=${FZF_QUERY:-}
    fi
    query=$(trim_string "$query")

    if [[ -z "$query" ]]; then
        query=$(selected_item_title "$item")
        query=$(trim_string "$query")
    fi

    if [[ -z "$query" ]]; then
        printf 'change-header(Ctrl-A needs a query or selected result)+bell\n'
        return
    fi

    seed=$(selected_item_parent_seed "$item" || true)
    if [[ -z "$seed" ]]; then
        seed=$(first_query_word "$query" || true)
    fi

    path=$(selected_item_path "$item")
    root=""
    if [[ -n "$path" ]]; then
        root=$(lib_for_path "$path" || true)
    fi

    write_state "$add_prev_mode_file" "$mode"
    write_state "$add_prev_query_file" "${FZF_QUERY:-}"
    write_state "$add_query_file" "$query"
    write_state "$add_seed_file" "$seed"
    write_state "$add_root_file" "$root"
    write_state "$mode_file" "add"

    printf '%s+transform-query(%s add-seed)+reload-sync(%s source-add)\n' \
        "$(actions_for_mode add)" "$0" "$0"
}

function preview_item ()
{
    local item=$1
    local kind path line title display

    IFS=$'\t' read -r kind path line title display <<< "$item"
    [[ -n "${path:-}" ]] || return 0

    case "$kind" in
        dir|add_dir)
            if command -v tree >/dev/null 2>&1; then
                tree -C "$path"
            else
                find "$path" -maxdepth 2 -name "$cache_dir_name" -prune -o -print 2>/dev/null
            fi
            ;;
        content|man_content)
            "$bat_path" --color=always "$path" --highlight-line "${line:-1}" 2>/dev/null || true
            ;;
        file|man_file)
            "$bat_path" --color=always "$path" 2>/dev/null || true
            ;;
    esac
}

function accept_add ()
{
    local item=$1
    local picker_query=${FZF_QUERY:-}
    local kind path line title display
    local dest_dir root rel note query cursor_line

    IFS=$'\t' read -r kind path line title display <<< "$item"
    if [[ "${FZF_MATCH_COUNT:-1}" != "0" && "$kind" == "add_dir" && -n "${path:-}" ]]; then
        dest_dir="$path"
    else
        rel=$(safe_relative_dir "$picker_query") || exit 1
        root=$(choose_new_dir_root) || exit 1
        dest_dir="$root/$rel"
    fi

    query=$(read_state "$add_query_file" "")
    note=$(create_note "$dest_dir" "$query") || exit 1
    cursor_line=$(note_body_line "$note")
    exec $editor "$note" "+$cursor_line"
}

function accept_item ()
{
    local item=$1
    local kind path line title display

    if [[ "$(current_mode)" == "add" ]]; then
        accept_add "$item"
        exit $?
    fi

    IFS=$'\t' read -r kind path line title display <<< "$item"
    [[ -n "${path:-}" ]] || exit 1

    case "$kind" in
        content|man_content)
            if [[ "${line:-0}" =~ ^[0-9]+$ && "$line" -gt 0 ]]; then
                exec $editor "$path" "+$line"
            fi
            exec $editor "$path"
            ;;
        file|dir|man_file)
            exec $editor "$path"
            ;;
        *)
            exit 1
            ;;
    esac
}

case "${1:-}" in
    source) source_current ;;
    source-live) source_live ;;
    source-filter) source_filter ;;
    source-add) source_add ;;
    refresh-caches) refresh_caches ;;
    rebuild-source) rebuild_caches_and_source ;;
    live-query) live_query ;;
    add-seed) add_seed ;;
    add-prev-query) add_prev_query ;;
    on-change) on_change ;;
    switch-top) switch_top ;;
    toggle-submode) toggle_submode ;;
    toggle-filter) toggle_filter ;;
    toggle-add)
        shift
        toggle_add "${1:-}"
        ;;
    preview)
        shift
        preview_item "${1:-}"
        ;;
    accept)
        shift
        accept_item "${1:-}"
        ;;
esac
NEITH_FZF_HELPER
    chmod +x "$helper"

    export NEITH_FZF_TMP="$tmp_dir"
    export NEITH_FZF_LIBS_FILE="$libs_file"
    export NEITH_FD_PATH
    export NEITH_FZF_PATH
    export NEITH_RG_PATH
    export NEITH_BAT_PATH
    export NEITH_NOTE_TEMPLATE
    export NEITH_CACHE_DIR_NAME
    export NEITH_CACHE_REFRESH_SECONDS

    "$helper" refresh-caches >/dev/null 2>&1 &

    "$NEITH_FZF_PATH" --ansi --query "$INITIAL_QUERY" \
        --prompt 'F:file> ' \
        --header 'Tab: mode | Ctrl-T: toggle | Ctrl-F: filter | Ctrl-R: refresh | Ctrl-A: add | Enter: open | Esc: quit' \
        --bind "start:reload-sync($helper source)" \
        --bind "change:transform($helper on-change)" \
        --bind "tab:transform($helper switch-top)" \
        --bind "ctrl-t:transform($helper toggle-submode)" \
        --bind "ctrl-f:transform($helper toggle-filter)" \
        --bind "ctrl-r:reload-sync($helper rebuild-source)" \
        --bind "ctrl-a:transform($helper toggle-add {})" \
        --bind "enter:become($helper accept {})" \
        --bind 'esc:abort' \
        --color "hl:-1:underline,hl+:-1:underline:reverse" \
        --delimiter $'\t' \
        --with-nth '5..' \
        --nth '1' \
        --ignore-case \
        --preview "$helper preview {}" \
        --preview-window 'up,60%,border-bottom,+{3}+3/3,~3'
fi
